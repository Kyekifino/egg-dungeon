#!/bin/sh
# Run smoke test — abort commit if game.js fails to initialise
node smoke.js || exit 1

# Lint
npm run lint || exit 1

# Unit tests with coverage enforcement (≥50% lines)
npm test || exit 1

# Ensure patch notes exist for the incoming version
node -e "
import { readFileSync } from 'fs';
const src = readFileSync('modules/utils.js', 'utf8');
const m = src.match(/export const VERSION = '([0-9]+)\.([0-9]+)'/);
if (!m) process.exit(0);
const next = m[1] + '.' + (Number(m[2]) + 1);
const pnIdx = src.indexOf('export const PATCH_NOTES');
if (pnIdx === -1) {
  console.error('  ERROR: PATCH_NOTES not found in modules/utils.js');
  process.exit(1);
}
const pnSection = src.slice(pnIdx, pnIdx + 4000);
if (!pnSection.includes(\"'\" + next + \"'\")) {
  console.error('  ERROR: No patch notes entry for v' + next);
  console.error(\"  Add a PATCH_NOTES['\" + next + \"'] entry before committing.\");
  process.exit(1);
}
console.log('  patch notes found for v' + next);
" --input-type=module || exit 1

# Bump the minor version in modules/utils.js
node -e "
import { readFileSync, writeFileSync } from 'fs';
const src = readFileSync('modules/utils.js', 'utf8');
const m = src.match(/export const VERSION = '([0-9]+)\.([0-9]+)'/);
if (!m) process.exit(0);
const next = m[1] + '.' + (Number(m[2]) + 1);
writeFileSync('modules/utils.js', src.replace(m[0], \"export const VERSION = '\" + next + \"'\"));
console.log('  version bumped to v' + next);
" --input-type=module && git add modules/utils.js
